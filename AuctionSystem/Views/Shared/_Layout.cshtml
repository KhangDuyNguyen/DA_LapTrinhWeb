@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var userName = User.Identity?.Name?.Split('@')[0] ?? "Tài khoản";
    var userInitial = string.IsNullOrWhiteSpace(userName) ? "U" : userName.Substring(0, 1).ToUpper();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuctionHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <nav class="navbar">
            <div class="nav-container">
                <a class="nav-brand" asp-controller="Home" asp-action="Index" aria-label="AuctionHub">
                    <span class="brand-mark"><i class="fas fa-gavel"></i></span>
                    <span class="brand-text">AuctionHub</span>
                </a>

                <button class="nav-toggle" id="navToggle" type="button" aria-label="Mở menu">
                    <i class="fas fa-bars"></i>
                </button>

                <div class="nav-menu" id="navMenu">
                    <div class="nav-links">
                        <a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" ? "active" : "")">
                            <i class="fas fa-house"></i> Trang chủ
                        </a>
                        <a asp-controller="Auction" asp-action="Index" class="@(currentController == "Auction" && currentAction == "Index" ? "active" : "")">
                            <i class="fas fa-layer-group"></i> Phiên đấu giá
                        </a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Auction" asp-action="Create" class="@(currentController == "Auction" && currentAction == "Create" ? "active" : "")">
                                <i class="fas fa-circle-plus"></i> Tạo phiên
                            </a>
                            <a asp-controller="Auction" asp-action="MyAuctions" class="@(currentController == "Auction" && currentAction == "MyAuctions" ? "active" : "")">
                                <i class="fas fa-box-open"></i> Của tôi
                            </a>
                            <a asp-controller="Auction" asp-action="MyBids" class="@(currentController == "Auction" && currentAction == "MyBids" ? "active" : "")">
                                <i class="fas fa-clock-rotate-left"></i> Lịch sử
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Index" class="nav-admin @(currentController == "Admin" ? "active" : "")">
                                <i class="fas fa-shield-halved"></i> Admin
                            </a>
                        }
                    </div>

                    <div class="nav-right">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="nav-user-dropdown">
                                <button class="nav-avatar" id="userMenuBtn" type="button">
                                    <span class="avatar-dot">@userInitial</span>
                                    <span>@userName</span>
                                    <i class="fas fa-chevron-down"></i>
                                </button>
                                <div class="user-dropdown-menu" id="userDropdown">
                                    <a asp-controller="Account" asp-action="Profile" class="dd-item"><i class="fas fa-user"></i> Hồ sơ cá nhân</a>
                                    <a asp-controller="Auction" asp-action="MyAuctions" class="dd-item"><i class="fas fa-gavel"></i> Phiên của tôi</a>
                                    <a asp-controller="Auction" asp-action="MyBids" class="dd-item"><i class="fas fa-receipt"></i> Lịch sử đặt giá</a>
                                    <a asp-controller="Account" asp-action="ChangePassword" class="dd-item"><i class="fas fa-key"></i> Đổi mật khẩu</a>
                                    <div class="dd-divider"></div>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dd-item dd-logout"><i class="fas fa-arrow-right-from-bracket"></i> Đăng xuất</button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn-ghost">Đăng nhập</a>
                            <a asp-controller="Account" asp-action="Register" class="btn-primary btn-nav-register">Đăng ký</a>
                        }
                    </div>
                </div>
            </div>
        </nav>

        @if (TempData["Success"] != null)
        {
            <div id="globalToast" class="toast toast-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div id="globalToast" class="toast toast-error"><i class="fas fa-circle-exclamation"></i> @TempData["Error"]</div>
        }

        <main class="main-content">
            @RenderBody()
        </main>

        <footer class="footer">
            <div class="footer-container">
                <div class="footer-brand-block">
                    <a class="nav-brand footer-brand" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark"><i class="fas fa-gavel"></i></span>
                        <span class="brand-text">AuctionHub</span>
                    </a>
                    <p>Nền tảng đấu giá trực tuyến với giao diện cream-canvas, rõ ràng và tập trung vào trải nghiệm đặt giá realtime.</p>
                </div>
                <div class="footer-links-grid">
                    <div>
                        <h4>Khám phá</h4>
                        <a asp-controller="Auction" asp-action="Index">Phiên đấu giá</a>
                        <a asp-controller="Auction" asp-action="Create">Tạo phiên mới</a>
                        <a asp-controller="Home" asp-action="Index">Đang diễn ra</a>
                    </div>
                    <div>
                        <h4>Hỗ trợ</h4>
                        <a href="#">Hướng dẫn đấu giá</a>
                        <a href="#">Quy chế hoạt động</a>
                        <a href="#">Liên hệ hỗ trợ</a>
                    </div>
                    <div>
                        <h4>Kết nối</h4>
                        <div class="footer-social">
                            <a href="#" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
                            <a href="#" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">© 2026 AuctionHub. Warm editorial auction interface.</div>
        </footer>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const navToggle = document.getElementById('navToggle');
        const navMenu = document.getElementById('navMenu');
        navToggle?.addEventListener('click', () => navMenu?.classList.toggle('show'));

        const btn = document.getElementById('userMenuBtn');
        const menu = document.getElementById('userDropdown');
        btn?.addEventListener('click', e => {
            e.stopPropagation();
            menu?.classList.toggle('show');
        });
        document.addEventListener('click', () => menu?.classList.remove('show'));

        const toast = document.getElementById('globalToast');
        if (toast) {
            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 400);
            }, 3500);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
