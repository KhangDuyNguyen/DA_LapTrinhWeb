@model IEnumerable<AuctionItem>
@{ ViewData["Title"] = "Phiên chờ duyệt"; }

<div class="page-header">
    <div>
        <span class="page-kicker"><i class="fas fa-clock"></i> Review queue</span>
        <h1>Phiên chờ duyệt (@Model.Count())</h1>
    </div>
    <a asp-action="Index" class="btn-secondary"><i class="fas fa-arrow-left"></i> Dashboard</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="admin-list"><div class="alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div></div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-check-circle" style="color:var(--success);"></i>
        <p>Không có phiên nào chờ duyệt!</p>
    </div>
}
else
{
    <div class="admin-list">
        @foreach (var item in Model)
        {
            <div class="card pending-card">
                <div class="pending-thumb">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Title" />
                    }
                    else
                    {
                        <i class="fas fa-image"></i>
                    }
                </div>
                <div>
                    <h3 style="color:var(--dark);font-size:18px;margin-bottom:6px;">@item.Title</h3>
                    <p style="color:var(--muted);margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">@item.Description</p>
                    <div class="pending-meta">
                        <span><i class="fas fa-user"></i> @item.CreatedByUser?.FullName</span>
                        <span><i class="fas fa-coins"></i> @item.StartingPrice.ToString("N0") VNĐ</span>
                        <span><i class="fas fa-calendar"></i> @item.StartTime.ToString("HH:mm dd/MM") → @item.EndTime.ToString("HH:mm dd/MM")</span>
                        <span><i class="fas fa-tag"></i> @(item.Category?.Name ?? "Khác")</span>
                    </div>
                </div>
                <div class="pending-actions">
                    <form asp-action="ApproveAuction" asp-route-id="@item.Id" method="post">
                        <button type="submit" class="btn-primary" style="width:100%;"><i class="fas fa-check"></i> Duyệt</button>
                    </form>
                    <form asp-action="RejectAuction" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa phiên này?')">
                        <button type="submit" class="btn-secondary" style="width:100%;color:var(--danger);"><i class="fas fa-xmark"></i> Từ chối</button>
                    </form>
                </div>
            </div>
        }
    </div>
}
